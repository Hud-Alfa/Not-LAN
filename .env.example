# Firebase Console → Project settings → Your apps → SDK setup (Web veya genel yapılandırma)
# Bu dosyayı .env olarak kopyalayın ve kendi projenizin değerleriyle doldurun.
# Expo: EXPO_PUBLIC_ ile başlayan değişkenler istemciye gömülür; asla sunucu gizli anahtarı koymayın.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# İsteğe bağlı (Analytics kullanıyorsanız)
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
